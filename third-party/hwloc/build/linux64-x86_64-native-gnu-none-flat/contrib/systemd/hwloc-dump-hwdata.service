[Unit]
Description=Dump hardware topology and locality information to /tmp/eronagha/chapel/third-party/hwloc/install/linux64-x86_64-native-gnu-none-flat/var/run/hwloc

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/tmp/eronagha/chapel/third-party/hwloc/install/linux64-x86_64-native-gnu-none-flat/sbin/hwloc-dump-hwdata -o /tmp/eronagha/chapel/third-party/hwloc/install/linux64-x86_64-native-gnu-none-flat/var/run/hwloc

[Install]
WantedBy=multi-user.target
